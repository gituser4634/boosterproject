generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  BOOSTER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  RELEASED
  FAILED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum NotificationType {
  NEW_REQUEST
  ORDER_ACCEPTED
  MESSAGE
  PAYMENT_RELEASED
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  username        String         @unique
  email           String         @unique
  password        String
  role            Role
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  boosterProfile  BoosterProfile?
  wallet          Wallet?
  customerOrders  Order[]        @relation("CustomerOrders")
  sentMessages    Message[]      @relation("MessageSender")
  reviewsGiven    Review[]       @relation("ReviewCustomer")
  reportsFiled    Report[]       @relation("ReportReporter")
  reportsReceived Report[]       @relation("ReportReportedUser")
  notifications   Notification[]

  @@index([role])
  @@index([isActive])
}

model BoosterProfile {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @unique @db.Uuid
  displayName   String
  country       String
  age           Int
  mainGameId    String            @db.Uuid
  averageRating Decimal           @default(0) @db.Decimal(3, 2)
  totalReviews  Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainGame      Game              @relation("BoosterMainGame", fields: [mainGameId], references: [id], onDelete: Restrict)
  boosterGames  BoosterGame[]
  reviews       Review[]          @relation("BoosterReviews")
  orders        Order[]           @relation("BoosterOrders")
  socials       BoosterSocial[]
  languages     BoosterLanguage[]
  payouts       Payout[]

  @@index([mainGameId])
  @@index([country])
  @@index([averageRating])
}

model Game {
  id                   String          @id @default(uuid()) @db.Uuid
  name                 String          @unique
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  ranks                Rank[]
  mainGameBoosters     BoosterProfile[] @relation("BoosterMainGame")
  boosterGames         BoosterGame[]
  orders               Order[]
}

model Rank {
  id               String       @id @default(uuid()) @db.Uuid
  name             String
  order            Int
  gameId           String       @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  game             Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  currentForOrders Order[]      @relation("OrderCurrentRank")
  targetForOrders  Order[]      @relation("OrderTargetRank")
  boosterGames     BoosterGame[]

  @@unique([gameId, name])
  @@unique([gameId, order])
  @@index([gameId])
}

model BoosterGame {
  id             String         @id @default(uuid()) @db.Uuid
  boosterId      String         @db.Uuid
  gameId         String         @db.Uuid
  rankId         String         @db.Uuid
  inGameUsername String         @default("")
  createdAt      DateTime       @default(now())
  booster        BoosterProfile @relation(fields: [boosterId], references: [id], onDelete: Cascade)
  game           Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rank           Rank           @relation(fields: [rankId], references: [id], onDelete: Restrict)

  @@unique([boosterId, gameId])
  @@index([gameId])
  @@index([rankId])
}

model Order {
  id             String              @id @default(uuid()) @db.Uuid
  title          String?
  customerId     String              @db.Uuid
  boosterId      String              @db.Uuid
  gameId         String              @db.Uuid
  currentRankId  String              @db.Uuid
  targetRankId   String              @db.Uuid
  price          Decimal             @db.Decimal(10, 2)
  status         OrderStatus         @default(PENDING)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  customer       User                @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  booster        BoosterProfile      @relation("BoosterOrders", fields: [boosterId], references: [id], onDelete: Restrict)
  game           Game                @relation(fields: [gameId], references: [id], onDelete: Restrict)
  currentRank    Rank                @relation("OrderCurrentRank", fields: [currentRankId], references: [id], onDelete: Restrict)
  targetRank     Rank                @relation("OrderTargetRank", fields: [targetRankId], references: [id], onDelete: Restrict)
  messages       Message[]
  payment        Payment?
  statusHistory  OrderStatusHistory[]

  @@index([customerId])
  @@index([boosterId])
  @@index([gameId])
  @@index([status, createdAt])
}

model OrderStatusHistory {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @db.Uuid
  status    OrderStatus
  changedAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @unique @db.Uuid
  amount      Decimal       @db.Decimal(10, 2)
  boosterShare Decimal      @db.Decimal(10, 2)
  platformFee Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payout {
  id        String       @id @default(uuid()) @db.Uuid
  boosterId String       @db.Uuid
  amount    Decimal      @db.Decimal(10, 2)
  status    PayoutStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  booster   BoosterProfile @relation(fields: [boosterId], references: [id], onDelete: Cascade)

  @@index([boosterId])
  @@index([status, createdAt])
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  senderId  String   @db.Uuid
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender    User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([senderId])
  @@index([orderId, createdAt])
}

model Review {
  id         String         @id @default(uuid()) @db.Uuid
  boosterId  String         @db.Uuid
  customerId String         @db.Uuid
  rating     Int
  comment    String         @default("")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  booster    BoosterProfile @relation("BoosterReviews", fields: [boosterId], references: [id], onDelete: Cascade)
  customer   User           @relation("ReviewCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([boosterId, customerId])
  @@index([boosterId])
  @@index([customerId])
}

model Report {
  id             String   @id @default(uuid()) @db.Uuid
  reporterId     String   @db.Uuid
  reportedUserId String   @db.Uuid
  reason         String
  createdAt      DateTime @default(now())
  reporter       User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser   User     @relation("ReportReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([reportedUserId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
}

model BoosterSocial {
  id        String         @id @default(uuid()) @db.Uuid
  boosterId String         @db.Uuid
  platform  String
  link      String
  createdAt DateTime       @default(now())
  booster   BoosterProfile @relation(fields: [boosterId], references: [id], onDelete: Cascade)

  @@unique([boosterId, platform])
  @@index([boosterId])
}

model BoosterLanguage {
  id        String         @id @default(uuid()) @db.Uuid
  boosterId String         @db.Uuid
  language  String
  createdAt DateTime       @default(now())
  booster   BoosterProfile @relation(fields: [boosterId], references: [id], onDelete: Cascade)

  @@unique([boosterId, language])
  @@index([boosterId])
}
