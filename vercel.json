  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": [
    "DATABASE_URL",
    "DIRECT_URL",
    "NEXTAUTH_SECRET",
    "AUTH_SECRET",
    "NEXT_PUBLIC_SUPABASE_URL",
